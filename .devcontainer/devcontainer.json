{
  "name": "skyrim-llm-runtime-rust",
  "image": "mcr.microsoft.com/devcontainers/rust:1-1-bookworm",
  "mounts": [
    "source=codex-home,target=/home/vscode/.codex,type=volume",
    "source=rust-cache,target=/home/vscode/.cargo,type=volume",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,consistency=cached",
    "source=E:\\Modding\\VistulaRim\\MO2\\mods\\SkyrimLLMRuntime,target=/skyrim-mod,type=bind,consistency=cached",
    "source=E:\\Modding\\VistulaRim,target=/host-vistularim,type=bind,consistency=cached"
  ],
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/vscode/.codex/bin:/home/vscode/.local/bin",
    "SKYRIM_LLM_HOST_BUILD_DIR": "/host-vistularim/skyrim-llm-runtime-build"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "vadimcn.vscode-lldb",
        "tamasfe.even-better-toml",
        "fill-labs.dependi",
        "openai.chatgpt",
        "yzhang.markdown-all-in-one",
        "ms-vscode.cpptools-extension-pack"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "rust-analyzer.check.command": "clippy"
      }
    }
  }
}
